modules = ["nodejs-22"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start frontend"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx server/index.ts"
waitForPort = 5000

[[workflows.workflow]]
name = "Start frontend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx expo start --tunnel --port 8080"
waitForPort = 8080

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[userenv]

[userenv.shared]
NODE_VERSION = "20.19.4"
EMAIL_FROM = "product@romeojuliet.love"
EMAIL_FROM_NAME = "Romeo & Juliet"
APP_URL = "https://romeojuliet.love"
EXPO_PUBLIC_API_URL = "https://f2bf1624-84d1-4f32-8c8f-c5d4ecc5395b-00-2vjuetglalcgo.sisko.replit.dev"
