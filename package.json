{
  "name": "rj-app",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "eslint .",
    "test": "jest --watchAll=false",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elevenlabs/react-native": "^1.2.3",
    "@expo-google-fonts/caveat": "^0.4.2",
    "@expo-google-fonts/cormorant-garamond": "^0.4.1",
    "@expo-google-fonts/eb-garamond": "^0.4.2",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo/metro-runtime": "~6.1.2",
    "@livekit/react-native": "2.9.8",
    "@livekit/react-native-webrtc": "137.0.3",
    "@react-native-community/netinfo": "^11.4.1",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-query": "^5.51.0",
    "base64-arraybuffer": "^1.0.2",
    "expo": "~54.0.35",
    "expo-auth-session": "~7.0.11",
    "expo-av": "~16.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-local-authentication": "~17.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.7",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.5",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "~0.21.2",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@expo/ngrok": "^4.1.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.5.0",
    "@types/react": "~19.0.10",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "react-test-renderer": "19.0.0",
    "typescript": "~5.8.3"
  },
  "jest": {
    "preset": "react-native",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|react-native-url-polyfill|expo|expo-.*|@expo/.*|@supabase/.*)/)"
    ]
  },
  "overrides": {
    "@livekit/react-native": "2.9.8",
    "@livekit/react-native-webrtc": "137.0.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": ["expo-av", "base64-arraybuffer"],
        "listUnknownPackages": false
      }
    },
    "install": {
      "exclude": [
        "react",
        "react-dom",
        "react-native",
        "react-native-reanimated",
        "react-native-gesture-handler",
        "react-native-safe-area-context",
        "react-native-screens",
        "react-native-svg",
        "react-native-web",
        "react-native-webview",
        "expo-splash-screen",
        "@types/react",
        "typescript"
      ]
    }
  },
  "private": true,
  "engines": {
    "node": ">=20.19.4"
  }
}
